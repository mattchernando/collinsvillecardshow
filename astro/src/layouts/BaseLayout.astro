---
import '../styles/global.css';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  /** Pass page-specific JSON-LD objects (FAQPage, BreadcrumbList, etc.) */
  extraSchema?: object[];
  /** 'index, follow' by default */
  robots?: string;
}

const {
  title,
  description,
  image = '/og-image.png',
  canonical = Astro.url.href,
  extraSchema = [],
  robots = 'index, follow',
} = Astro.props;

const siteUrl = 'https://collinsvillecardshow.com';
const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;
const fullCanonical = canonical.startsWith('http') ? canonical : `${siteUrl}${canonical}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f59e0b" />

    <!-- Geo Meta — local SEO signal -->
    <meta name="geo.region" content="US-IL" />
    <meta name="geo.placename" content="Collinsville, Illinois" />
    <meta name="geo.position" content="38.6706;-89.9845" />
    <meta name="ICBM" content="38.6706, -89.9845" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Collinsville Card Show" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Collinsville Card Show — Trading Cards & Collectibles in Collinsville, IL near St. Louis" />
    <meta property="og:url" content={fullCanonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    <meta name="twitter:image:alt" content="Collinsville Card Show — Trading Cards & Collectibles in Collinsville, IL near St. Louis" />

    <!-- Favicon / Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!--
      Google Fonts — no Subresource Integrity (SRI) hash applied.
      Google Fonts serves different CSS content per User-Agent (browser-specific
      font formats), so a pinned integrity hash would break the stylesheet for
      any browser that receives different content. If we later self-host Inter
      via fontsource or a similar package, we can add SRI at that point.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Structured Data (Event + LocalBusiness — always present) -->
    <StructuredData canonical={fullCanonical} image={fullImageUrl} />

    <!-- Page-specific structured data (FAQ, Breadcrumb, etc.) -->
    {extraSchema.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen bg-gray-950 text-white overflow-x-hidden" style="font-family: 'Inter', system-ui, sans-serif;">
    <slot />
  </body>
</html>
