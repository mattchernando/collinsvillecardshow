---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import About from '../components/About.astro';
import WhyAttend from '../components/WhyAttend.astro';
import Categories from '../components/Categories.astro';
import UpcomingShows from '../components/UpcomingShows.astro';
import SocialProof from '../components/SocialProof.astro';
import VendorCTA from '../components/VendorCTA.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import { homepageFAQ, buildFAQSchema } from '../data/seo';

const title = "Collinsville Card Show | Sports Cards, Pokémon & Collectibles Near St. Louis";
const description = "The Collinsville Card Show is Southern Illinois' premier trading card and collectibles event — held monthly in Collinsville, IL, just minutes from St. Louis. 100 vendor tables, free admission, free parking. Sports cards, Pokémon, Magic: The Gathering, Funko, LEGO and more.";

const faqSchema = buildFAQSchema(homepageFAQ);
---

<BaseLayout
  title={title}
  description={description}
  image="/og-image.png"
  canonical="https://collinsvillecardshow.com/"
  extraSchema={[faqSchema]}
>
  <Nav />
  <Hero />
  <StatsBar />
  <About />
  <WhyAttend />
  <Categories />
  <UpcomingShows />
  <SocialProof />
  <VendorCTA />
  <FAQ />
  <Footer />
</BaseLayout>
