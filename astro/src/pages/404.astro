---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Collinsville Card Show"
  description="The page you're looking for doesn't exist."
  canonical="https://collinsvillecardshow.com/404"
>
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <div class="text-8xl font-black text-amber-400 mb-4">404</div>
      <h1 class="text-3xl font-black text-white mb-4">Page not found</h1>
      <p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex px-8 py-4 bg-gradient-to-r from-amber-400 to-orange-500 text-gray-950 font-black text-lg rounded-2xl hover:scale-105 transition-transform"
      >
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>
