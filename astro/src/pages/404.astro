---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Collinsville Card Show"
  description="The page you're looking for doesn't exist."
>
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <p class="text-8xl font-black bg-gradient-to-r from-amber-400 to-orange-600 bg-clip-text text-transparent mb-4">404</p>
      <h1 class="text-3xl font-bold text-white mb-4">Page not found</h1>
      <p class="text-gray-400 text-lg mb-8">
        Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-amber-400 to-orange-500 text-gray-950 font-black text-lg rounded-2xl hover:scale-105 transition-all shadow-lg shadow-amber-500/25"
      >
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>
