---
// About section — fully static
---

<section id="about" class="py-24 px-4">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <div>
      <div class="text-sm font-bold text-amber-400 uppercase tracking-widest mb-4">About the Show</div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight mb-6">
        The <span class="text-amber-400">Midwest's</span> Favorite Card Show
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed mb-6">
        Held at The Crossings Church in Collinsville, IL, our show brings together collectors, dealers, and enthusiasts from across the St. Louis Metro East region. Whether you're hunting for rare vintage cards, the latest Pokémon releases, or unique collectibles — you'll find it here.
      </p>
      <p class="text-gray-400 text-lg leading-relaxed mb-8">
        With close to 100 vendor tables and free admission, it's the perfect place for both seasoned collectors and newcomers to explore, trade, and discover. Located just minutes from downtown St. Louis, Belleville, Edwardsville, O'Fallon, and Fairview Heights.
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-semibold text-gray-300">Free Admission</span>
        <span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-semibold text-gray-300">Free Parking</span>
        <span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-semibold text-gray-300">Family Friendly</span>
        <span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-semibold text-gray-300">All Ages</span>
      </div>
    </div>

    <div class="space-y-4">
      <div class="group p-5 bg-gray-900 border border-gray-800 rounded-2xl hover:border-amber-500/50 transition-all cursor-default">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-gray-950 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-amber-400 uppercase tracking-wider">Location</div>
            <div class="text-lg font-bold text-white">The Crossings Church</div>
            <div class="text-sm text-gray-500">2002 Mall Street, Collinsville, IL 62234</div>
          </div>
        </div>
      </div>

      <div class="group p-5 bg-gray-900 border border-gray-800 rounded-2xl hover:border-amber-500/50 transition-all cursor-default">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-gray-950 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-amber-400 uppercase tracking-wider">Hours</div>
            <div class="text-lg font-bold text-white">9:00 AM – 3:00 PM</div>
            <div class="text-sm text-gray-500">Vendor setup begins at 7:30 AM</div>
          </div>
        </div>
      </div>

      <div class="group p-5 bg-gray-900 border border-gray-800 rounded-2xl hover:border-amber-500/50 transition-all cursor-default">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-gray-950 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-amber-400 uppercase tracking-wider">Contact</div>
            <div class="text-lg font-bold text-white">(618) 729-6999</div>
            <div class="text-sm text-gray-500">Call or text for vendor inquiries</div>
          </div>
        </div>
      </div>

      <div class="group p-5 bg-gray-900 border border-gray-800 rounded-2xl hover:border-amber-500/50 transition-all cursor-default">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-gray-950 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
          </div>
          <div>
            <div class="text-xs font-bold text-amber-400 uppercase tracking-wider">Admission</div>
            <div class="text-lg font-bold text-white">Completely FREE</div>
            <div class="text-sm text-gray-500">Free parking available on-site</div>
          </div>
        </div>
      </div>

      <!-- Google Maps -->
      <div class="rounded-2xl overflow-hidden border border-gray-800">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3116.5!2d-89.9845!3d38.6706!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87df5541ddafa3f9%3A0x12b028d4b0c42935!2s2002%20Mall%20St%2C%20Collinsville%2C%20IL%2062234!5e0!3m2!1sen!2sus!4v1700000000000"
          width="100%"
          height="200"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Collinsville Card Show location — 2002 Mall Street, Collinsville, IL 62234"
        ></iframe>
      </div>
    </div>
  </div>
</section>
