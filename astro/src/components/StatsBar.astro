---
import AnimatedCounter from './AnimatedCounter.jsx';
---

<section class="relative py-16 bg-gradient-to-r from-amber-600 via-orange-600 to-red-600">
  <div class="max-w-5xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8">
    <AnimatedCounter client:visible end={100} label="Vendor Tables" />
    <AnimatedCounter client:visible end={8} label="Categories" />
    <AnimatedCounter client:visible end={1000} label="Attendees" />
    <AnimatedCounter client:visible end={6} label="Shows / Year" />
  </div>
</section>
