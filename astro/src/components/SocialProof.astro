---
// SocialProof — placeholder testimonials / photo gallery section
// Replace quotes with real testimonials as they come in
const testimonials = [
  {
    quote: "Best card show in the St. Louis area, hands down. Great vendors, great prices, and free admission — can't beat it.",
    name: "Jason M.",
    role: "Sports Card Collector",
  },
  {
    quote: "My kids love coming to this show. They bring their binders and trade Pokémon cards with other kids. It's become a monthly tradition for our family.",
    name: "Sarah T.",
    role: "Parent & Collector",
  },
  {
    quote: "I've been vending at card shows for years and this one consistently draws a solid crowd. Well-organized and the venue is great.",
    name: "Mike R.",
    role: "Card Show Vendor",
  },
];
---

<section id="testimonials" class="py-24 px-4 bg-gray-900/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-sm font-bold text-amber-400 uppercase tracking-widest mb-4">What People Are Saying</div>
      <h2 class="text-4xl md:text-5xl font-black">
        Loved by <span class="text-amber-400">Collectors</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="p-6 bg-gray-900 border border-gray-800 rounded-2xl hover:border-gray-700 transition-colors">
          <!-- Star rating -->
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400 fill-amber-400" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
          <blockquote class="text-gray-300 leading-relaxed mb-4">"{t.quote}"</blockquote>
          <div>
            <div class="font-bold text-white">{t.name}</div>
            <div class="text-sm text-gray-500">{t.role}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Social proof CTA -->
    <div class="mt-12 text-center">
      <p class="text-gray-400 mb-4">Follow us on Facebook for show updates, vendor spotlights, and more</p>
      <a
        href="https://www.facebook.com/people/Collinsville-Card-Show/61575725262148/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-gray-700 text-white font-black text-lg rounded-2xl hover:border-amber-500/50 hover:bg-white/5 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Follow Us on Facebook
      </a>
    </div>
  </div>
</section>
